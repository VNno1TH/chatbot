OLLAMA_BASE_URL=http://localhost:11435
OLLAMA_MODEL=qwen2.5:14b
RERANKER_URL=http://localhost:8080
USE_REMOTE_RERANKER=1

OLLAMA_EMBED_MODEL=bge-m3:latest

# ── Router ──
ROUTER_MODEL=qwen2.5:14b
ROUTER_TIMEOUT=20

# ── Retriever ──
# Tắt/bật từng tính năng nếu cần debug
HYDE_ENABLED=1
QUERY_REWRITE_ENABLED=1
SELF_REFLECT_ENABLED=1
RETRIEVER_LLM_TIMEOUT=6

# ── Debug ──
HAUI_DEBUG=1    # Đặt thành 1 để xem log chi tiết từng bước

# ── Telegram Bot ──
# Lấy token từ BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# ── Admin ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=haui2026
SECRET_KEY=haui-chatbot-secret-key-2026-change-me
